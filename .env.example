# Скопируйте этот файл в .env и заполните значения:  cp .env.example .env

# --- DeepSeek API ---
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- Период выборки новостей (часов назад от момента запуска) ---
LOOKBACK_HOURS=24

# --- Получатель письма (email; при установке через deploy.sh запрашивается) ---
MAIL_TO=

# --- Режим отправки ---
# direct = свой мини-MTA: письмо отдаётся напрямую на MX-сервер получателя,
#          внешний SMTP-аккаунт не нужен (требуется открытый исходящий порт 25).
# relay  = через внешний SMTP-аккаунт (заполните SMTP_* ниже).
SEND_MODE=direct

# Адрес отправителя (от кого письмо). Домен должен существовать.
# При установке через deploy.sh подставляется как news-agent@<домен_получателя>.
SMTP_FROM=
# Имя для EHLO (FQDN). Пусто — берётся домен из SMTP_FROM.
EHLO_HOSTNAME=

# --- DKIM-подпись (для SEND_MODE=direct) ---
# Сгенерировать ключ:
#   openssl genrsa -out keys/dkim_private.pem 2048
#   openssl rsa -in keys/dkim_private.pem -pubout -out keys/dkim_public.pem
# Затем опубликовать публичный ключ в DNS как TXT: <selector>._domainkey.<domain>
# DKIM_DOMAIN при установке через deploy.sh берётся из домена получателя.
DKIM_SELECTOR=newsagent
DKIM_DOMAIN=
DKIM_PRIVATE_KEY=keys/dkim_private.pem

# --- SMTP-аккаунт (только для SEND_MODE=relay) ---
# SMTP_SSL=true для порта 465 (SSL), false для 587 (STARTTLS)
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_SSL=true
